<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Capstone Notes Automation Suite"
       parallel="methods"
       thread-count="3"
       verbose="2">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.capstone.utils.AnnotationTransformer"/>
    </listeners>

    <!-- Chrome Test Run (Primary) -->
    <test name="Chrome - All Scenarios" preserve-order="false">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.capstone.runners.TestRunner"/>
        </classes>
    </test>

    <!-- Firefox Test Run (Uncomment for cross-browser) -->
